# Copy this file to .env and fill in your keys

# Required — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional — defaults to gpt-4o-mini (cheapest, fast)
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Required for live market data — get from https://finnhub.io (free tier available)
FINNHUB_API_KEY=your_finnhub_key_here

# Optional — only needed if using pgvector (Postgres with pgvector extension)
# Format: postgresql+asyncpg://user:password@host:5432/dbname
# Leave blank to use in-memory cosine similarity (works fine for dev/demo)
DATABASE_URL=

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
